    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.561.0",
    "multer": "^2.0.2",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  }
}
