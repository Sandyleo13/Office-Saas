{
  "name": "officeflow-mini-saas",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.js",
    "postinstall": "prisma generate",
    "seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vitejs/plugin-react": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "express": "^5.2.1",
    "html-pdf-node": "^1.0.8",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.561.0",
    "mammoth": "^1.12.0",
    "multer": "^2.0.2",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
